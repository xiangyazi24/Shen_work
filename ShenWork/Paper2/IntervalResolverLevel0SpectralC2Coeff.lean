/-- Level-0 trajectory used in the B-form Picard construction: the heat semigroup
iterate `conjugatePicardIter p u‚āÄ 0`. -/
abbrev heatLevel0 (p : CM2Params) (u‚āÄ : intervalDomainPoint ‚Üí ‚ĄĚ) :
    ‚ĄĚ ‚Üí intervalDomainPoint ‚Üí ‚ĄĚ :=
  conjugatePicardIter p u‚āÄ 0

/-- Restart offset for a positive interior time `t‚āÄ`: the positive half-time
`t‚āÄ / 2`. -/
def halfOffset (t‚āÄ : ‚ĄĚ) : ‚ĄĚ :=
  t‚āÄ / 2

/-- Initial coefficients at the restart offset. -/
def level0ResolverRestartA0
    (p : CM2Params) (u‚āÄ : intervalDomainPoint ‚Üí ‚ĄĚ) (t‚āÄ : ‚ĄĚ) : ‚Ąē ‚Üí ‚ĄĚ :=
  fun k => resolverTimeCoeff p (heatLevel0 p u‚āÄ) k (halfOffset t‚āÄ)

/-- Restart source coefficients generated by the scalar ODE
`c' = a - őĽ c` for `c(t) = resolverTimeCoeff p (heatLevel0 p u‚āÄ) k t`.

The `k`-th source is
`deriv c_k(offset + ŌĀ) + őĽ_k c_k(offset + ŌĀ)`. -/
def level0ResolverRestartSource
    (p : CM2Params) (u‚āÄ : intervalDomainPoint ‚Üí ‚ĄĚ) (t‚āÄ : ‚ĄĚ) : ‚ĄĚ ‚Üí ‚Ąē ‚Üí ‚ĄĚ :=
  fun ŌĀ k =>
    deriv (resolverTimeCoeff p (heatLevel0 p u‚āÄ) k) (halfOffset t‚āÄ + ŌĀ) +
      unitIntervalCosineEigenvalue k *
        resolverTimeCoeff p (heatLevel0 p u‚āÄ) k (halfOffset t‚āÄ + ŌĀ)

/-- The coefficient-level variation-of-constants identity specialized to the
level-0 resolver coefficient family.

This is the concrete step requested in the prompt: after restarting at
`offset = t‚āÄ/2`, the local restart coefficient recovers
`resolverTimeCoeff ... k s` for `s` near `t‚āÄ`, provided `s ‚Č• offset`.
The only analytic inputs are the C¬Ļ facts needed to invoke
`localRestartCoeff_variation_of_constants` for the scalar function
`t ‚Ü¶ resolverTimeCoeff p (heatLevel0 p u‚āÄ) k t`. -/
theorem level0Resolver_localRestartCoeff_eq
    (p : CM2Params) (u‚āÄ : intervalDomainPoint ‚Üí ‚ĄĚ) (t‚āÄ s : ‚ĄĚ)
    (hs : halfOffset t‚āÄ ‚Č§ s)
    (k : ‚Ąē)
    (hderiv : ‚ąÄ t : ‚ĄĚ,
      HasDerivAt (resolverTimeCoeff p (heatLevel0 p u‚āÄ) k)
        (deriv (resolverTimeCoeff p (heatLevel0 p u‚āÄ) k) t) t)
    (hderiv_cont : Continuous
      (fun t : ‚ĄĚ => deriv (resolverTimeCoeff p (heatLevel0 p u‚āÄ) k) t)) :
    localRestartCoeff
        (level0ResolverRestartA0 p u‚āÄ t‚āÄ)
        (level0ResolverRestartSource p u‚āÄ t‚āÄ)
        (s - halfOffset t‚āÄ) k =
      resolverTimeCoeff p (heatLevel0 p u‚āÄ) k s := by
  have hŌĀ : 0 ‚Č§ s - halfOffset t‚āÄ := sub_nonneg.mpr hs
  have hvoc :=
    ShenWork.Paper2.RestartVariationOfConstants.localRestartCoeff_variation_of_constants
      (c := resolverTimeCoeff p (heatLevel0 p u‚āÄ) k)
      hderiv hderiv_cont
      (halfOffset t‚āÄ) (s - halfOffset t‚āÄ) hŌĀ k
  have hő∑ŌĀ : halfOffset t‚āÄ + (s - halfOffset t‚āÄ) = s := by ring
  simpa [level0ResolverRestartA0, level0ResolverRestartSource, hő∑ŌĀ]
    using hvoc

/-- Assemble the strengthened spectral-agreement package for the heat Level0
resolver from the variation-of-constants identity.

The proof deliberately keeps four analytic inputs as `sorry` blocks:

* `ha0_bound`: uniform bound for the restart initial coefficients at `t‚āÄ/2`;
* `srcC2`: the strengthened `DuhamelSourceTimeC2Coeff` package for the restart
  source. This is the largest missing bridge, because the existing physical
  resolver route bypasses the spectral őĽ¬≤/őĽ¬≥ ladder;
* `hcoeff_deriv` / `hcoeff_deriv_cont`: scalar C¬Ļ facts for each
  `resolverTimeCoeff`; these should follow from the positive-time source C¬≤ data
  and the constant elliptic weight factorization;
* `hresolver_series`: cosine reconstruction of the concrete resolver value.

Everything else is bookkeeping plus the variation-of-constants identity. -/
theorem resolverHasSpectralAgreementC2Coeff_heatLevel0
    (p : CM2Params) (u‚āÄ : intervalDomainPoint ‚Üí ‚ĄĚ) {T : ‚ĄĚ} (_hT : 0 < T) :
    ResolverHasSpectralAgreementC2Coeff T
      (coupledChemicalConcentration p (heatLevel0 p u‚āÄ)) := by
  let u : ‚ĄĚ ‚Üí intervalDomainPoint ‚Üí ‚ĄĚ := heatLevel0 p u‚āÄ

  /- Cosine reconstruction of the concrete elliptic resolver.
     This should be obtained from `intervalNeumannResolverR` /
     `resolverR_eq_cosineSeries` and the definition of `resolverTimeCoeff`. -/
  have hresolver_series : ‚ąÄ s : ‚ĄĚ, 0 < s ‚Üí s < T ‚Üí ‚ąÄ x : intervalDomainPoint,
      coupledChemicalConcentration p u s x =
        ‚ąĎ' k : ‚Ąē, resolverTimeCoeff p u k s * cosineMode k x.1 := by
    intro s _hs _hsT x
    have hlift := ShenWork.IntervalResolverJointC2PhysicalConcrete.coupledChemical_lift_eq_series
      (p := p) (u := u) (t := s) (x := x.1) x.2
    have hlift_eq : ShenWork.IntervalDomain.intervalDomainLift
        (coupledChemicalConcentration p u s) x.1 = coupledChemicalConcentration p u s x := by
      simp [ShenWork.IntervalDomain.intervalDomainLift, x.2]
    rw [hlift_eq] at hlift
    simpa [ShenWork.IntervalResolverJointC2Physical.boundedWeightJointTerm] using hlift

  have hmake : ‚ąÄ t‚āÄ : ‚ĄĚ, 0 < t‚āÄ ‚Üí t‚āÄ < T ‚Üí
      ‚ąÉ (a‚āÄ : ‚Ąē ‚Üí ‚ĄĚ) (M : ‚ĄĚ) (_ : 0 ‚Č§ M) (_ : ‚ąÄ n, |a‚āÄ n| ‚Č§ M)
        (a : ‚ĄĚ ‚Üí ‚Ąē ‚Üí ‚ĄĚ) (_ : DuhamelSourceTimeC2Coeff a) (offset : ‚ĄĚ),
        (0 < t‚āÄ - offset) ‚ąß
        (‚ąÄŠ∂† s in ūĚďĚ t‚āÄ, ‚ąÄ x : intervalDomainPoint,
          coupledChemicalConcentration p u s x =
            ‚ąĎ' n, localRestartCoeff a‚āÄ a (s - offset) n * cosineMode n x.1) := by
    intro t‚āÄ ht‚āÄ ht‚āÄT
    let offset : ‚ĄĚ := halfOffset t‚āÄ
    let a‚āÄ : ‚Ąē ‚Üí ‚ĄĚ := level0ResolverRestartA0 p u‚āÄ t‚āÄ
    let a : ‚ĄĚ ‚Üí ‚Ąē ‚Üí ‚ĄĚ := level0ResolverRestartSource p u‚āÄ t‚āÄ

    have hoff_pos : 0 < offset := by
      dsimp [offset, halfOffset]
      linarith

    have hŌĄ‚āÄ : 0 < t‚āÄ - offset := by
      dsimp [offset, halfOffset]
      linarith

    obtain ‚ü®M, hM, ha‚āÄ‚ü© :
        ‚ąÉ M : ‚ĄĚ, 0 ‚Č§ M ‚ąß ‚ąÄ n : ‚Ąē, |a‚āÄ n| ‚Č§ M := by
      -- TODO: bound the resolver coefficients at the fixed positive time
      -- `offset = t‚āÄ/2`.  For Level0 heat this should follow from the resolver
      -- cosine coefficient square/decay estimate plus `offset > 0` heat smoothing.
      -- A crude bound such as a finite sup/envelope at the positive time suffices.
      sorry

    have srcC2 : DuhamelSourceTimeC2Coeff a := by
      -- TODO: build the strengthened source package for
      --   a ŌĀ k = c'_k(offset+ŌĀ) + őĽ_k c_k(offset+ŌĀ),
      -- where c_k(t) = resolverTimeCoeff p u k t.
      -- Required fields:
      --   * DuhamelSourceTimeC1 a: HasDerivAt in ŌĀ, continuous adot,
      --     ‚Ąď¬Ļ envelope for a, uniform bound for adot;
      --   * őĽ-weighted and őĽ¬≤-weighted envelopes for a;
      --   * őĽ-weighted and őĽ¬≤-weighted envelopes for adot.
      -- For Level0 heat, these should come from positive-time exponential
      -- heat smoothing, resolver weight `1/(őľ+őĽ_k)`, and the source-side
      -- `srcTimeCoeff_contDiffAt`/bounds.  This is not presently packaged in
      -- the repo; the committed physical resolver lane bypasses this structure.
      sorry

    have hcoeff_deriv : ‚ąÄ k : ‚Ąē, ‚ąÄ t : ‚ĄĚ,
        HasDerivAt (resolverTimeCoeff p u k)
          (deriv (resolverTimeCoeff p u k) t) t := by
      -- TODO: derive from positive-time `ContDiff` of resolver coefficients.
      -- If the heat Level0 coefficient family is only smooth on `(0,‚ąě)`, then
      -- either use its smooth positive-time extension or replace the VOC lemma
      -- by a local/windowed variant.  The current VOC lemma has a global C¬Ļ
      -- hypothesis, so this block supplies exactly that interface.
      sorry

    have hcoeff_deriv_cont : ‚ąÄ k : ‚Ąē,
        Continuous (fun t : ‚ĄĚ => deriv (resolverTimeCoeff p u k) t) := by
      -- TODO: same source as above; `ContDiff ‚ĄĚ 2` gives continuity of the first
      -- derivative.  Source-side theorem already present:
      -- `IntervalPhysicalSourceTimeC2Concrete.srcTimeCoeff_contDiffAt`, plus
      -- `resolverTimeCoeff_eq_weight_smul` transfers through the constant
      -- elliptic weight.
      sorry

    have hagree : ‚ąÄŠ∂† s in ūĚďĚ t‚āÄ, ‚ąÄ x : intervalDomainPoint,
        coupledChemicalConcentration p u s x =
          ‚ąĎ' n, localRestartCoeff a‚āÄ a (s - offset) n * cosineMode n x.1 := by
      have hnear_time : Set.Ioo (0 : ‚ĄĚ) T ‚ą© Set.Ioi offset ‚ąą ūĚďĚ t‚āÄ := by
        exact Filter.inter_mem
          (isOpen_Ioo.mem_nhds ‚ü®ht‚āÄ, ht‚āÄT‚ü©)
          (isOpen_Ioi.mem_nhds (by
            show halfOffset t‚āÄ < t‚āÄ
            simp only [halfOffset]
            linarith))
      filter_upwards [hnear_time] with s hs x
      have hs0 : 0 < s := hs.1.1
      have hsT : s < T := hs.1.2
      have hsoff : offset ‚Č§ s := le_of_lt hs.2
      have hcoeff_eq : ‚ąÄ k : ‚Ąē,
          localRestartCoeff a‚āÄ a (s - offset) k = resolverTimeCoeff p u k s := by
        intro k
        have h := level0Resolver_localRestartCoeff_eq
          (p := p) (u‚āÄ := u‚āÄ) (t‚āÄ := t‚āÄ) (s := s) hsoff k
          (hcoeff_deriv k) (hcoeff_deriv_cont k)
        simpa [u, a‚āÄ, a, offset] using h
      have hsum :
          (‚ąĎ' k : ‚Ąē, localRestartCoeff a‚āÄ a (s - offset) k * cosineMode k x.1) =
            ‚ąĎ' k : ‚Ąē, resolverTimeCoeff p u k s * cosineMode k x.1 := by
        apply tsum_congr
        intro k
        rw [hcoeff_eq k]
      rw [hresolver_series s hs0 hsT x, ‚Üź hsum]

    exact ‚ü®a‚āÄ, M, hM, ha‚āÄ, a, srcC2, offset, hŌĄ‚āÄ, hagree‚ü©

  refine ‚ü®?toSpectralAgreement, hmake‚ü©
  refine { exists_data := ?_ }
  intro t‚āÄ ht‚āÄ ht‚āÄT
  rcases hmake t‚āÄ ht‚āÄ ht‚āÄT with
    ‚ü®a‚āÄ, M, hM, ha‚āÄ, a, srcC2, offset, hŌĄ‚āÄ, hagree‚ü©
  exact ‚ü®a‚āÄ, M, hM, ha‚āÄ, a, srcC2.toTimeC1, offset, hŌĄ‚āÄ, hagree‚ü©

